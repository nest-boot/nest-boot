{
  "name": "@nest-boot/example-all-in-one",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "nest start --watch | pino-pretty",
    "dev:debug": "nest start --debug --watch",
    "repl": "nest start --entryFile repl",
    "start": "node --import ./scripts/nestjs-graphql-require-shim.mjs dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --import ./scripts/nestjs-graphql-require-shim.mjs dist/main.js",
    "start:e2e": "node scripts/start-e2e-server.mjs",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typedoc:check": "typedoc --treatValidationWarningsAsErrors --emit none",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "migration:create": "mikro-orm migration:create",
    "migration:up": "mikro-orm migration:up",
    "migration:down": "mikro-orm migration:down",
    "seeder:create": "mikro-orm seeder:create",
    "seeder:run": "mikro-orm seeder:run"
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express5": "^1.1.2",
    "@casl/ability": "^6.7.5",
    "@mikro-orm/core": "7.1.4",
    "@mikro-orm/decorators": "7.1.4",
    "@mikro-orm/migrations": "7.1.4",
    "@mikro-orm/nestjs": "^7.0.2",
    "@mikro-orm/postgresql": "7.1.4",
    "@mikro-orm/reflection": "7.1.4",
    "@mikro-orm/seeder": "7.1.4",
    "@mikro-orm/sql": "7.1.4",
    "@nest-boot/auth": "workspace:^",
    "@nest-boot/crypt": "workspace:^",
    "@nest-boot/graphql": "workspace:^",
    "@nest-boot/graphql-connection": "workspace:^",
    "@nest-boot/logger": "workspace:^",
    "@nest-boot/middleware": "workspace:^",
    "@nest-boot/mikro-orm": "workspace:^",
    "@nest-boot/permission": "workspace:^",
    "@nest-boot/request-context": "workspace:^",
    "@nest-boot/row-level-security": "workspace:^",
    "@nestjs/apollo": "next",
    "@nestjs/common": "next",
    "@nestjs/config": "next",
    "@nestjs/core": "next",
    "@nestjs/graphql": "next",
    "@nestjs/platform-express": "next",
    "@node-rs/jieba": "^2.0.1",
    "better-auth": "^1.4.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.18",
    "express": "^5.1.0",
    "graphql": "^16.11.0",
    "ioredis": "^5.8.0",
    "jose": "^6.1.3",
    "lodash-es": "^4.17.21",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sonyflake-js": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@mikro-orm/cli": "7.1.4",
    "@nest-boot/eslint-config": "workspace:^",
    "@nest-boot/eslint-plugin": "workspace:^",
    "@nest-boot/tsconfig": "workspace:^",
    "@nestjs/cli": "next",
    "@nestjs/schematics": "next",
    "@nestjs/testing": "next",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts",
      "./dist/mikro-orm.config.js"
    ]
  }
}
