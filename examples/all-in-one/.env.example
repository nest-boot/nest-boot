TZ=UTC

APP_NAME="Nest Boot All In One"
APP_URL=http://localhost:3000
APP_SECRET=change-me-in-local-development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_boot_all_in_one

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
AUTH_OIDC_ENABLED=false
AUTH_OIDC_ID=example-client-id
AUTH_OIDC_SECRET=example-client-secret
AUTH_OIDC_ISSUER="https://auth.example.test/oidc"
AUTH_OIDC_DISCOVERY_URL="https://auth.example.test/oidc/.well-known/openid-configuration"

# Gemini
GOOGLE_GENERATIVE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_GENERATIVE_AI_API_KEY=replace-me
