{
  "extends": "@nest-boot/tsconfig/library.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "src",
    "test",
    "vitest.setup.ts",
    "vitest.config.ts",
    "vitest.config.e2e.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
