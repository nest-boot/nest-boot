{
  "name": "@nest-boot/row-level-security",
  "version": "7.3.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/nest-boot/nest-boot.git",
    "directory": "packages/row-level-security"
  },
  "description": "PostgreSQL row level security helpers for Nest Boot applications",
  "author": {
    "name": "Xudong Huang",
    "email": "me@huangxudong.com",
    "url": "https://www.huangxudong.com/"
  },
  "homepage": "",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "lib": "dist"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf .nx && rm -rf node_modules && rm -rf dist",
    "dev": "tsc -w -p tsconfig.build.json",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts"
  },
  "peerDependencies": {
    "@mikro-orm/migrations": "^7.0.0",
    "@mikro-orm/postgresql": "^7.0.0",
    "@mikro-orm/sql": "^7.0.0",
    "@nest-boot/request-context": "workspace:^",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@mikro-orm/core": "7.1.4",
    "@mikro-orm/decorators": "7.1.4",
    "@mikro-orm/migrations": "7.1.4",
    "@mikro-orm/nestjs": "^7.0.2",
    "@mikro-orm/postgresql": "7.1.4",
    "@mikro-orm/reflection": "7.1.4",
    "@mikro-orm/sql": "7.1.4",
    "@nest-boot/eslint-config": "workspace:^",
    "@nest-boot/eslint-plugin": "workspace:^",
    "@nest-boot/mikro-orm": "workspace:^",
    "@nest-boot/request-context": "workspace:^",
    "@nest-boot/tsconfig": "workspace:^",
    "@nestjs/common": "next",
    "@nestjs/core": "next",
    "@nestjs/testing": "next",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "pgsql-ast-parser": "^12.0.2"
  },
  "type": "module"
}
