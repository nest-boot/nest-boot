{
  "name": "@nest-boot/permission",
  "version": "7.2.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/nest-boot/nest-boot.git",
    "directory": "packages/permission"
  },
  "description": "CASL-based permission helpers for Nest Boot applications",
  "author": {
    "name": "Xudong Huang",
    "email": "me@huangxudong.com",
    "url": "https://www.huangxudong.com/"
  },
  "homepage": "",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "lib": "dist"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf .nx && rm -rf node_modules && rm -rf dist",
    "dev": "tsc -w -p tsconfig.build.json",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "test:debug": "vitest --inspect-brk --no-file-parallelism"
  },
  "peerDependencies": {
    "@casl/ability": "^6.0.0",
    "@nest-boot/request-context": "workspace:^",
    "@nestjs/common": "^12.0.0-alpha.5",
    "@nestjs/core": "^12.0.0-alpha.5",
    "express": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@casl/ability": "^6.7.5",
    "@nest-boot/eslint-config": "workspace:^",
    "@nest-boot/eslint-plugin": "workspace:^",
    "@nest-boot/request-context": "workspace:^",
    "@nest-boot/tsconfig": "workspace:^",
    "@nestjs/common": "next",
    "@nestjs/core": "next",
    "@nestjs/testing": "next",
    "@types/express": "^5.0.3",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.3",
    "express": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "type": "module"
}
