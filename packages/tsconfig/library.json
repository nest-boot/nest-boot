{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Library",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2023",
    "moduleResolution": "NodeNext"
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/*.e2e-spec.ts",
    "vitest.setup.ts"
  ]
}
