{
  "private": true,
  "name": "@nest-boot/workspace",
  "repository": {
    "type": "git",
    "url": "https://github.com/nest-boot/nest-boot.git"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "commit:check": "lint-staged && pnpm docs:check",
    "commitlint": "commitlint",
    "cz": "cz",
    "prepare": "husky install",
    "build": "nx run-many -t build",
    "build:docs": "nx run @nest-boot/docs:build",
    "build:packages": "nx run-many -t build --exclude=@nest-boot/docs",
    "clean": "nx reset && nx run-many -t clean && rm -rf node_modules",
    "dev": "nx run-many -t dev --exclude=@nest-boot/docs --parallel=100 --skip-nx-cache",
    "dev:docs": "nx run @nest-boot/docs:dev",
    "test": "jest",
    "test:cov": "jest --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "docs:check": "pnpm build:packages && pnpm typedoc:check",
    "docs:generate": "typedoc --treatValidationWarningsAsErrors && rimraf apps/docs/content/docs/api/index.mdx",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint:fix",
    "typedoc:check": "typedoc --treatValidationWarningsAsErrors --emit none",
    "release:dry-run": "nx release --dry-run --skip-publish"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@nest-boot/tsconfig": "workspace:^",
    "@nx/js": "^22.7.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "nx": "^22.7.5",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.17",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.10.0"
  },
  "lint-staged": {
    "*.{md,json}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "volta": {
    "node": "24.14.0"
  }
}
